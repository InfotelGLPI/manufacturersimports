<form name="form" method="post" action="{{ target }}">
    <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}">

    <div class="card mb-3">
        <div class="card-header">
            <strong>{{ __('Choose inventory type and manufacturer', 'manufacturersimports') }}</strong>
        </div>
        <div class="card-body">
            {% if has_configs %}
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    {% do call('Dropdown::showFromArray', [
                        'itemtype',
                        type_opts,
                        {'value': itemtype, 'display_emptychoice': true}
                    ]) %}
                    {% do call('Dropdown::showFromArray', [
                        'manufacturers_id',
                        manufacturer_opts,
                        {'value': manufacturers_id}
                    ]) %}
                    {% do call('Dropdown::showFromArray', [
                        'imported',
                        imported_opts,
                        {'value': imported}
                    ]) %}
                    <button type="submit" name="typechoice" class="btn btn-primary">
                        {{ _x('button', 'Post') }}
                    </button>
                </div>
            {% else %}
                {% if can_config %}
                    <a class="btn btn-primary" href="{{ config_url }}">
                        {{ __('No manufacturer available. Please configure at least one manufacturer', 'manufacturersimports') }}
                    </a>
                {% else %}
                    <div class="alert alert-warning">
                        {{ __('No manufacturer available. Please configure at least one manufacturer', 'manufacturersimports') }}
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </div>
</form>
